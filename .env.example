# Avatar — environment variables.
# Copy this file to `.env` in the project root and fill in real values.
# The .env is loaded by the backend (python-dotenv) and is NEVER baked into the
# Docker image — it is passed at runtime (--env-file) or staged as Fly secrets.
# See README.md "Setup instructions" for how to obtain each value.

# --- LLM (OpenRouter) ---------------------------------------------------------
# Your OpenRouter API key (https://openrouter.ai/keys). Starts with sk-or-v1-.
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# OpenRouter model id (must use the openai/... prefix). The cheap dev/test default
# is openai/gpt-5.4-nano; the reference production model is openai/gpt-5.4-mini.
MODEL=openai/gpt-5.4-nano

# --- Identity -----------------------------------------------------------------
# The person this Digital Twin represents. Shown in the UI (header/subtitle, page
# title, how the Avatar refers to itself, and on your "live" messages from admin).
# Never hardcoded anywhere — each owner sets their own.
OWNER_NAME=Emil Dermendzhiev

# Password for the /admin dashboard. Choose a strong value.
ADMIN_PASSWORD=change-me-to-a-strong-password

# --- Pushover (optional) ------------------------------------------------------
# Used by the push tool to notify you when a visitor wants to get in touch or a
# question needs a human. Leave blank to disable (the tool no-ops gracefully).
PUSHOVER_USER=
PUSHOVER_TOKEN=

# --- Supabase -----------------------------------------------------------------
# Project base URL WITHOUT the trailing /rest/v1/ (e.g. https://abcd.supabase.co).
SUPABASE_URL=https://your-project-ref.supabase.co
# The new-style SECRET key (starts with sb_secret_). Backend-only; full DB access.
SUPABASE_KEY=sb_secret_your-secret-key-here

# --- Session / cookie ---------------------------------------------------------
# Signs the admin session cookie. Optional locally (falls back to a value derived
# from ADMIN_PASSWORD), but set a long random value for production so rotating the
# admin password does not invalidate live sessions, e.g. `openssl rand -hex 32`.
SESSION_SECRET=set-a-long-random-string-for-production

# Set to 1 in production (HTTPS) so the admin cookie is Secure. Leave 0/unset for
# local http. In the Fly deployment this is forced to 1 via scripts/fly.toml.
COOKIE_SECURE=0
